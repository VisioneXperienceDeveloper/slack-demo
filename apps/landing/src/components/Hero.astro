---
---
<section class="hero section-padding">
  <div class="container hero-content">
    <div class="hero-text-area">
      <div class="badge animate-fade-in">New: Version 2.0 is now live</div>
      <h1 class="hero-title animate-fade-in">
        Connect with your team <br />
        <span class="text-gradient">instantly and securely</span>
      </h1>
      <p class="hero-description animate-fade-in">
        Minimal, fast, and professional communication for modern engineering teams. 
        Focus on what matters most with our Linear-inspired design.
      </p>
      <div class="hero-actions animate-fade-in">
        <a href="https://app.slackclone.com/signup" class="btn btn-primary btn-lg">Start for Free</a>
        <a href="#features" class="btn btn-secondary btn-lg">Explore Features</a>
      </div>
    </div>
  </div>
  
  <div class="hero-glow"></div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: 140px;
    text-align: center;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 2;
  }

  .badge {
    display: inline-block;
    padding: 4px 12px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 99px;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .hero-title {
    font-size: clamp(40px, 8vw, 72px);
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.04em;
    margin-bottom: 24px;
  }

  .hero-description {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
  }

  .btn-lg {
    padding: 14px 28px;
    font-size: 16px;
  }

  .hero-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 1200px;
    height: 600px;
    background: radial-gradient(circle at center, rgba(255, 255, 255, 0.03) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 40px;
    }
  }
</style>
